# Copy this file to .env on the Debian host and edit before first start.

TZ=Africa/Johannesburg
PUID=1000
PGID=1000
UMASK=002

# Keep config and downloads on explicit Debian host paths.
# Final media libraries are mounted from the Windows cinema share below.
CONFIG_ROOT=/srv/media-stack/config
DOWNLOAD_ROOT=/srv/media-stack/downloads

# Windows media share. This maps \\192.168.137.110\cinema to /mnt/cinema.
SMB_MOUNT_SHARES=true
SMB_SOURCE=//192.168.137.110/cinema
SMB_MOUNT=/mnt/cinema
SMB_USERNAME=CHANGE_ME
SMB_PASSWORD=CHANGE_ME
SMB_DOMAIN=WORKGROUP
SMB_VERSION=3.0
SMB_CREDENTIALS_FILE=/etc/samba/credentials/cinema

# Host paths mounted into the containers as /data/media/*.
MOVIES_ROOT=/mnt/cinema/movies
SERIES_ROOT=/mnt/cinema/series
MUSIC_ROOT=/mnt/cinema/music

# Internal LAN reverse proxy hostnames. Point each DNS A record to the Debian proxy server.
RADARR_HOST=radarr.wolf.den
SONARR_HOST=sonarr.wolf.den
LIDARR_HOST=lidarr.wolf.den
NZBGET_HOST=nzbget.wolf.den
EMBY_STREAM_HOST=stream.wolf.den
EMBY_MAIN_HOST=emby.wolf.den
EMBY_STREAM_UPSTREAM=192.168.137.118:8096
EMBY_MAIN_UPSTREAM=192.168.137.110:8096

CADDY_HTTP_PORT=80

# Change this before exposing the stack to anyone else.
NZBGET_USER=nzbget
NZBGET_PASS=change-this-password
